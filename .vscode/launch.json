{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (.NET Core)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "watch-server",
      "program": "${workspaceFolder}/server/bin/Debug/net10.0/LifePlanner.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/server",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ],
  "compounds": [
    {
      "name": "Launch Full App",
      "configurations": ["Backend (.NET Core)"],
      "preLaunchTask": "run-all"
    }
  ]
}
